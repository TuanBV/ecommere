generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPING
  COMPLETED
  CANCELLED
}

model Banner {
  id          String    @id @db.VarChar(36)
  version     Int?      @default(0)
  title       String    @db.VarChar(255)
  imageUrl    String    @map("image_url") @db.VarChar(500)
  linkUrl     String?   @map("link_url") @db.VarChar(255)
  position    String?   @db.VarChar(50)
  startDate   DateTime? @map("start_date") @db.Timestamp(6)
  endDate     DateTime? @map("end_date") @db.Timestamp(6)
  isActive    Int?      @default(0) @map("is_active")
  delFlag     Int?      @default(0) @map("del_flag")
  createdDate DateTime? @map("created_date") @db.Timestamp(6)
  updatedDate DateTime? @map("updated_date") @db.Timestamp(6)

  @@map("banner")
}

model Brand {
  id          String    @id @db.VarChar(36)
  version     Int?      @default(0)
  title       String    @unique @db.VarChar(50)
  logo        String?   @db.VarChar(500)
  delFlag     Int?      @default(0) @map("del_flag")
  createdDate DateTime? @map("created_date") @db.Timestamp(6)
  updatedDate DateTime? @map("updated_date") @db.Timestamp(6)
  slug        String?   @db.VarChar(100)
  products    Product[]
  news        News[]

  @@index([slug], map: "idx_brand_slug")
  @@map("brand")
}

model Category {
  id          String    @id @db.VarChar(36)
  version     Int?      @default(0)
  title       String    @unique @db.VarChar(50)
  logo        String?   @db.VarChar(500)
  priority    Int?      @default(0)
  delFlag     Int?      @default(0) @map("del_flag")
  createdDate DateTime? @map("created_date") @db.Timestamp(6)
  updatedDate DateTime? @map("updated_date") @db.Timestamp(6)
  slug        String?   @db.VarChar(100)
  products    Product[]
  news        News[]

  @@index([slug], map: "idx_category_slug")
  @@map("category")
}

model Contact {
  id          String    @id @db.VarChar(36)
  version     Int?
  fullName    String    @map("full_name") @db.VarChar(255)
  phone       String    @db.VarChar(20)
  serviceType String?   @map("service_type") @db.VarChar(100)
  message     String?   @db.Text
  status      String?   @default("NEW") @db.VarChar(50)
  note        String?   @db.Text
  delFlag     Int?      @default(0) @map("del_flag")
  createdDate DateTime? @map("created_date") @db.Timestamp(6)
  updatedDate DateTime? @map("updated_date") @db.Timestamp(6)

  @@index([phone], map: "idx_contact_phone")
  @@index([status], map: "idx_contact_status")
  @@map("contact")
}

model News {
  id          String    @id @db.VarChar(36)
  version     Int?      @default(0)
  title       String    @db.VarChar(255)
  slug        String    @unique(map: "uk_news_slug") @db.VarChar(255)
  summary     String?   @db.VarChar(1000)
  content     String    @db.LongText
  thumbnail   String?   @db.VarChar(500)
  categoryId  String?   @map("category_id") @db.VarChar(36)
  brandId     String?   @map("brand_id") @db.VarChar(36)
  status      String?   @default("DRAFT") @db.VarChar(20)
  postType    String?   @default("NEWS") @map("post_type") @db.VarChar(20)
  metaTitle   String?   @map("meta_title") @db.VarChar(255)
  metaKeyword String?   @map("meta_keyword") @db.VarChar(255)
  metaDesc    String?   @map("meta_desc") @db.VarChar(1000)
  viewCount   Int?      @default(0) @map("view_count")
  isFeatured  Boolean?  @default(false) @map("is_featured") @db.Bit(1)
  authorId    String?   @map("author_id") @db.VarChar(36)
  delFlag     Int?      @default(0) @map("del_flag")
  createdDate DateTime? @map("created_date") @db.Timestamp(6)
  updatedDate DateTime? @map("updated_date") @db.Timestamp(6)
  category    Category? @relation(fields: [categoryId], references: [id])
  brand       Brand?    @relation(fields: [brandId], references: [id])
  author      User?     @relation(fields: [authorId], references: [id])

  @@index([slug], map: "idx_news_slug")
  @@index([status], map: "idx_news_status")
  @@index([categoryId], map: "idx_news_category")
  @@map("news")
}

model Order {
  id              String        @id @db.VarChar(36)
  version         Int?          @default(0)
  customerName    String        @map("customer_name") @db.VarChar(100)
  customerPhone   String        @map("customer_phone") @db.VarChar(15)
  customerEmail   String?       @map("customer_email") @db.VarChar(100)
  shippingAddress String        @map("shipping_address") @db.Text
  note            String?       @db.Text
  adminNote       String?       @map("admin_note") @db.Text
  totalAmount     Decimal       @default(0.00) @map("total_amount") @db.Decimal(15, 2)
  paymentMethod   String?       @default("COD") @map("payment_method") @db.VarChar(50)
  status          OrderStatus?  @default(PENDING)
  delFlag         Int?          @default(0) @map("del_flag")
  createdDate     DateTime?     @map("created_date") @db.Timestamp(6)
  updatedDate     DateTime?     @map("updated_date") @db.Timestamp(6)
  details         OrderDetail[]

  @@map("orders")
}

model OrderDetail {
  id          String    @id @db.VarChar(36)
  version     Int?      @default(0)
  orderId     String    @map("order_id") @db.VarChar(36)
  productId   String    @map("product_id") @db.VarChar(36)
  price       Decimal   @default(0.00) @db.Decimal(15, 2)
  quantity    Int
  delFlag     Int?      @default(0) @map("del_flag")
  createdDate DateTime? @map("created_date") @db.Timestamp(6)
  updatedDate DateTime? @map("updated_date") @db.Timestamp(6)
  order       Order     @relation(fields: [orderId], references: [id])
  product     Product   @relation(fields: [productId], references: [id])

  @@map("order_detail")
}

model Policy {
  id          String    @id @db.VarChar(36)
  version     Int?      @default(0)
  packageName String    @map("package_name") @db.VarChar(255)
  policies    Json?
  afterSales  Json?     @map("after_sales")
  gifts       Json?
  isActive    Int?      @default(0) @map("is_active")
  delFlag     Int?      @default(0) @map("del_flag")
  createdDate DateTime? @map("created_date") @db.Timestamp(6)
  updatedDate DateTime? @map("updated_date") @db.Timestamp(6)
  products    Product[]

  @@map("policy")
}

model Product {
  id            String        @id @db.VarChar(36)
  policyId      String?       @map("policy_id") @db.VarChar(36)
  version       Int?          @default(0)
  categoryId    String        @map("category_id") @db.VarChar(36)
  brandId       String        @map("brand_id") @db.VarChar(36)
  title         String        @db.VarChar(255)
  content       String?       @db.LongText
  specification String?       @db.LongText
  status        Int?          @default(1)
  delFlag       Int?          @default(0) @map("del_flag")
  createdDate   DateTime?     @map("created_date") @db.Timestamp(6)
  updatedDate   DateTime?     @map("updated_date") @db.Timestamp(6)
  sku           String        @db.VarChar(100)
  price         Decimal       @default(0.00) @db.Decimal(15, 2)
  salePrice     Decimal       @default(0.00) @map("sale_price") @db.Decimal(15, 2)
  stockQty      Int           @default(0) @map("stock_qty")
  color         String?       @db.VarChar(50)
  size          String?       @db.VarChar(50)
  image         String?       @db.VarChar(500)
  slug          String?       @db.VarChar(500)
  soldCount     Int           @default(0) @map("sold_count")
  groupId       String?       @map("group_id") @db.Text
  description   String?       @db.LongText
  variantName   String?       @map("variant_name") @db.VarChar(255)
  category      Category      @relation(fields: [categoryId], references: [id])
  brand         Brand         @relation(fields: [brandId], references: [id])
  policy        Policy?       @relation(fields: [policyId], references: [id])
  images        ProductImage[]
  orderDetails  OrderDetail[]
  reviews       Review[]

  @@map("product")
}

model ProductImage {
  id          String    @id @db.VarChar(36)
  version     Int?      @default(0)
  productId   String    @map("product_id") @db.VarChar(36)
  imageUrl    String    @map("image_url") @db.VarChar(500)
  delFlag     Int?      @default(0) @map("del_flag")
  createdDate DateTime? @map("created_date") @db.Timestamp(6)
  updatedDate DateTime? @map("updated_date") @db.Timestamp(6)
  sortOrder   Int?      @default(0) @map("sort_order")
  product     Product   @relation(fields: [productId], references: [id])

  @@map("product_image")
}

model ProductSimilar {
  id           String    @id @db.VarChar(36)
  version      Int?      @default(0)
  productGroup String?   @map("product_group") @db.Text
  delFlag      Int?      @default(0) @map("del_flag")
  createdDate  DateTime? @map("created_date") @db.Timestamp(6)
  updatedDate  DateTime? @map("updated_date") @db.Timestamp(6)

  @@map("product_similar")
}

model Review {
  id          String        @id @db.VarChar(36)
  version     Int?          @default(0)
  reviewName  String        @map("review_name") @db.VarChar(255)
  reviewEmail String        @map("review_email") @db.VarChar(255)
  content     String        @db.VarChar(1000)
  productId   String        @map("product_id") @db.VarChar(36)
  rating      Int?
  delFlag     Int           @default(0) @map("del_flag")
  createdDate DateTime?     @map("created_date") @db.Timestamp(6)
  updatedDate DateTime?     @map("updated_date") @db.Timestamp(6)
  product     Product       @relation(fields: [productId], references: [id])
  images      ReviewImage[]

  @@map("review")
}

model ReviewImage {
  id          String    @id @db.VarChar(36)
  version     Int?      @default(0)
  reviewId    String    @map("review_id") @db.VarChar(36)
  imageUrl    String    @map("image_url") @db.VarChar(255)
  delFlag     Int       @default(0) @map("del_flag")
  createdDate DateTime? @map("created_date") @db.Timestamp(6)
  updatedDate DateTime? @map("updated_date") @db.Timestamp(6)
  review      Review    @relation(fields: [reviewId], references: [id])

  @@map("review_image")
}

model Slider {
  id          String    @id @db.VarChar(36)
  version     Int?      @default(0)
  title       String    @db.VarChar(255)
  description String?   @db.Text
  imageUrl    String    @map("image_url") @db.VarChar(500)
  linkUrl     String?   @map("link_url") @db.VarChar(255)
  position    Int?      @default(1)
  isActive    Boolean?  @default(true) @map("is_active")
  delFlag     Int?      @default(0) @map("del_flag")
  createdDate DateTime? @map("created_date") @db.Timestamp(6)
  updatedDate DateTime? @map("updated_date") @db.Timestamp(6)

  @@map("slider")
}

model SysParam {
  id          BigInt    @id @default(autoincrement())
  version     Int?
  paramKey    String    @unique @map("param_key") @db.VarChar(100)
  paramValue  String    @map("param_value") @db.Text
  paramName   String    @map("param_name") @db.VarChar(255)
  groupCode   String?   @map("group_code") @db.VarChar(50)
  description String?   @db.VarChar(500)
  delFlag     Int?      @default(0) @map("del_flag")
  createdDate DateTime? @map("created_date") @db.Timestamp(6)
  updatedDate DateTime? @map("updated_date") @db.Timestamp(6)

  @@index([paramKey], map: "idx_param_key")
  @@map("sys_param")
}

model User {
  version     Int?
  createdDate DateTime?   @map("created_date") @db.Timestamp(6)
  updatedDate DateTime?   @map("updated_date") @db.Timestamp(6)
  phone       String?     @db.VarChar(15)
  id          String      @id @db.VarChar(36)
  username    String      @unique @db.VarChar(50)
  fullName    String?     @map("full_name") @db.VarChar(255)
  email       String      @unique @db.VarChar(100)
  password    String?     @db.VarChar(255)
  delFlag     Int?        @default(0) @map("del_flag")
  role        Int?        @default(1)
  images      UserImage[]
  news        News[]

  @@map("user")
}

model UserImage {
  id          String    @id @db.VarChar(36)
  url         String?   @db.VarChar(1000)
  imageOrder  Int?      @default(0) @map("image_order")
  delFlag     Int?      @default(0) @map("del_flag")
  createdDate DateTime? @map("created_date") @db.Timestamp(6)
  updatedDate DateTime? @map("updated_date") @db.Timestamp(6)
  userId      String?   @map("user_id") @db.VarChar(36)
  user        User?     @relation(fields: [userId], references: [id])

  @@map("user_image")
}
